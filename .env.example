# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# Your Canvas instance base URL (no trailing slash).
# Examples:
#   https://canvas.instructure.com
#   https://your-school.instructure.com
# CANVAS_API_URL=

# ---------------------------------------------------------------------
# AUTH — use ONE of the two options below.
# ---------------------------------------------------------------------

# Option A — Personal Access Token (preferred when available).
# Generate at: Account -> Settings -> New Access Token
# CANVAS_API_TOKEN=

# Option B — Session cookie (when your institution blocks PATs).
# Do NOT use document.cookie — canvas_session is HttpOnly and won't appear there.
# 1. Log into Canvas in your browser.
# 2. Open DevTools (F12 or Cmd+Opt+I) -> Network tab.
# 3. Reload or click around so a request fires; click any request to your Canvas host.
# 4. Right-click -> Copy -> Copy as cURL.
# 5. From the cURL, copy the value between the quotes after `-H 'Cookie: ...'`
#    (Safari/Firefox may use `-b '...'`). Must include canvas_session and _csrf_token;
#    log_session_id is recommended.
# 6. Paste below, wrapped in double quotes.
# After editing, restart Claude Code so the MCP server reloads this file.
# Cookie expires when you log out. Paste a fresh one if you get 401 errors.
# CANVAS_COOKIE=""
